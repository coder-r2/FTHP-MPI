#!/bin/bash

export PAREP_MPI_SRUN="$(which srun)"
export DYN_CONNECT=1
export PATH=/scratch/risheg/Fault-Tolerant-MPI/bin/parep_mpi_srun:$PATH
export PAREP_MPI_WORKDIR=/scratch/risheg/Fault-Tolerant-MPI
export LD_LIBRARY_PATH=/scratch/risheg/Fault-Tolerant-MPI/lib:$LD_LIBRARY_PATH

export PAREP_MPI_NODE_LIST=$(scontrol show hostname $SLURM_JOB_NODELIST)

export PAREP_CKPT_COORDINATOR_IP="$(hostname -i)"

nlist=($PAREP_MPI_NODE_LIST)

for ((x=0; x<$SLURM_JOB_NUM_NODES; x++))
do
	getent ahosts ${nlist[$x]} | grep ${nlist[$x]} | awk '{print $1}' >> $PAREP_MPI_WORKDIR/connection/nodelist
done

/opt/ohpc/pub/mpi/mvapich2-gnu12/2.3.7/bin/mpirun $@ &

unset LD_PRELOAD
/opt/ohpc/pub/mpi/mvapich2-gnu12/2.3.7/bin/mpirun --with-ft ulfm $@

rm -R /scratch/risheg/Fault-Tolerant-MPI/connection/*
rm -R /scratch/risheg/Fault-Tolerant-MPI/logs/*
for f in /scratch/risheg/Fault-Tolerant-MPI/tempwpid_*; do mv "$f" "$(echo "$f" | sed s/tempwpid/waitpid/)"; done
